# Auth0 — create a Regular Web Application at https://manage.auth0.com
# Allowed Callback URL:  http://localhost:3000/auth/callback
# Allowed Logout URL:     http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=                       # from Auth0 app (NOT the Google Client ID)
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=                          # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000

# Google sign-in: configure in Auth0 Dashboard → Authentication → Social → Google
# Paste your Google Client ID + Secret there (not in this file).
# Google Cloud authorized redirect URI must be:
#   https://YOUR_AUTH0_DOMAIN/login/callback

# Database — Vercel Postgres, Neon, or local PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/forgeara"

# Shopify Storefront API (optional — live product sync + unified checkout)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=